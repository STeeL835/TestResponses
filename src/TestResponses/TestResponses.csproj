<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>

    <PackageId>TestResponses</PackageId> 
    <Version>$(PackageUnifiedVersion)</Version>
    <Authors>Dmitrii Frolov</Authors>
    <Description>Readable, contextual API test responses for .NET</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/steel835/TestResponses</RepositoryUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageReleaseNotes Condition="'$(RELEASE_NOTES)' != ''">$(RELEASE_NOTES)</PackageReleaseNotes>

    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="\"/>
  </ItemGroup>
  
  
</Project>
